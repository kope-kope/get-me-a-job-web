# Copy to .env.local and fill in.
# .env.local is gitignored; never commit real values.

# ─── NextAuth ────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# ─── Google OAuth (required) ─────────────────────────────────────────────────
# Web application client — NOT the Desktop one.
# https://console.cloud.google.com/apis/credentials
# Google is always needed for Drive + Docs (saving your resume/letters), even
# if you send email through Resend or SMTP below.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Anthropic (required) ────────────────────────────────────────────────────
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
# Optional model overrides
# ANTHROPIC_MODEL=claude-sonnet-4-6
# ANTHROPIC_HUMANIZER_MODEL=claude-opus-4-7

# ─── Hunter.io (optional) ────────────────────────────────────────────────────
# Finds real contact emails at target companies.
# https://hunter.io/api-keys (25 free searches / month on the free tier)
# Leave blank to skip contact finding — resume + cover letter still work.
HUNTER_API_KEY=

# ─── Email provider ──────────────────────────────────────────────────────────
# How outreach emails are sent. One of: gmail | resend | smtp. Default: gmail.
#   gmail  — sends from the signed-in user's Gmail (no extra keys; can also
#            save drafts). Uses the Google OAuth above.
#   resend — sends via Resend's API. Set RESEND_API_KEY + EMAIL_FROM.
#   smtp   — sends via any SMTP server. Set SMTP_HOST (+ optional auth) + EMAIL_FROM.
# resend and smtp are send-only (no "save as draft").
EMAIL_PROVIDER=gmail

# Sender identity for resend/smtp (must be a verified/allowed sender).
# Example: "Your Name <you@yourdomain.com>"
# EMAIL_FROM=

# Resend — https://resend.com/api-keys
# RESEND_API_KEY=

# SMTP — from your mail host
# SMTP_HOST=
# SMTP_PORT=587          # 465 = implicit TLS; 587 = STARTTLS (default)
# SMTP_USER=
# SMTP_PASS=

# ─── App ─────────────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
