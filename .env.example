# Copy to .env.local and fill in.
# .env.local is gitignored; never commit real values.

# NextAuth
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# Google OAuth (Web application client — NOT the Desktop one)
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Anthropic
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
# Optional model overrides
# ANTHROPIC_MODEL=claude-sonnet-4-6
# ANTHROPIC_HUMANIZER_MODEL=claude-opus-4-7

# Hunter.io — for finding real contact emails at target companies (optional)
# https://hunter.io/api-keys (25 free searches / month on the free tier)
HUNTER_API_KEY=

# App
NEXTAUTH_URL=http://localhost:3000
